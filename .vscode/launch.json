{
  "version": "0.2.0",
  "logging": {
    "engineLogging": true
  },
  "configurations": [
    {
      "name": "Attach to backend in Docker",
      "type": "docker",
      "request": "attach",
      "platform": "netCore",
      "sourceFileMap": {
        "/src": "${workspaceFolder}"
      },
      "containerName": "archiemate_backend"
    },
    {
      "name": "Frontend only on Chrome",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/ArchieMate.Frontend/",
      "runtimeArgs": [
        "--load-extension=${env:userprofile}/AppData/Local/Google/Chrome/User Data/Default/Extensions/fmkadmapgofadopljbjfkapdkoienihi/4.27.1_1"
      ]
    }
  ]
}
