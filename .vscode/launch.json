{
  "version": "0.2.0",
  "logging": {
    "engineLogging": true
  },
  "configurations": [
    {
      "name": "Backend",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/ArchieMate.Backend/bin/Debug/net6.0/ArchieMate.Backend.dll",
      "envFile": "${workspaceFolder}/.env",
      "justMyCode": false,
      "suppressJITOptimizations": true,
      "symbolOptions": {
        "searchPaths": [],
        "searchMicrosoftSymbolServer": false,
        "searchNuGetOrgSymbolServer": false
      }
    },
    {
      "name": "Frontend only on Chrome",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/ArchieMate.Frontend/",
      "runtimeArgs": [
        "--load-extension=${env:userprofile}/AppData/Local/Google/Chrome/User Data/Default/Extensions/fmkadmapgofadopljbjfkapdkoienihi/4.27.1_1"
      ]
    }
  ]
}
